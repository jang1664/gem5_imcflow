##########################################################################################
# Makefile for ImcFlow RTL Co-Simulation with gem5
# Integrates DPI-C socket server with ImcFlow RTL
##########################################################################################

.PHONY: help
.DEFAULT_GOAL := help

SIMUL_EXEC = vcs
SIMUL_OPTS = ""
DEFINE = "SUPPORT_K2+SUPPORT_K3+SUPPORT_K5+SUPPORT_K7+FSIM+PROF+MEM_MODEL" # + separated
PARAM_FILE = "parameters.txt"
INCLUDE_DIR = "${IMCFLOW_DIR}/pmap/modules/top/include+${IMCFLOW_DIR}/pmap/classes+${IMCFLOW_DIR}/pmap/include"

# DPI-C compilation flags
DPI_FLAGS = -LDFLAGS -Wl,--no-as-needed

setup:
	mkdir -p logs
	mkdir -p reports
	touch ${PARAM_FILE}
	date > setup

clean: ## Clean logs and autogenerated files.
	rm -f *.log *.key *.history *.swp core.* transcript vsim.wlf vsim_stacktrace.vstf

clean_all: clean ## Clean entirely, excluding scripts and source files.
	rm -rf *.log *.key *.history *.saif *.d *shm core.* *.vcd init vc_hdrs.h
	rm -rf *.daidir *.vdb csrc simv *.dump *.vpd
	rm -rf verdiLog
	rm -rf *.fsdb*
	rm -rf verdi_config_file
	rm -rf logs reports _logs
	rm -rf compile* setup
	rm -rf ucli.key

compile: setup clean_all ## Compile the RTL co-simulation (usage: make compile DEFINE="<defparam>" SIMUL_OPTS="-opt1 -opt2")
	${SIMUL_EXEC} \
	-V -sverilog -full64 -debug_access+all -kdb \
	${DPI_FLAGS} \
	${SIMUL_OPTS} \
	+incdir+${INCLUDE_DIR} \
	+define+${DEFINE} \
	-parameters ${PARAM_FILE} \
	-timescale=1ns/1ps \
	-assert svaext \
	+warn=noUII-L \
	+warn=noIDTS \
	+lint=TFIPC-L \
	+lint=PCWM \
	+delay_mode_zero \
	-debug_region=cell \
	-xprop=tmerge \
	-f tech.f \
	-f rtl.f \
	-f tb.f \
	-o simv_imcflow_gem5
	date > compile

run: compile ## Run the RTL simulation (waits for gem5 connection on port 9999)
	@echo "=== Starting ImcFlow RTL Co-Simulation ==="
	@echo "Waiting for gem5 to connect on port 9999..."
	./simv_imcflow_gem5

sim: run ## Alias for run

verdi: ## Open Verdi waveform viewer
	verdi -ssf inter.fsdb -dbdir simv_imcflow_gem5.daidir

help:
	@echo "ImcFlow RTL Co-Simulation Makefile"
	@echo ""
	@echo "Available targets:"
	@grep -E '^[a-zA-Z_-]+:.*?## .*$$' $(MAKEFILE_LIST) | awk 'BEGIN {FS = ":.*?## "}; {printf "  \033[36m%-20s\033[0m %s\n", $$1, $$2}'
	@echo ""
	@echo "Usage examples:"
	@echo "  make compile              - Compile the simulation"
	@echo "  make run                  - Run simulation (waits for gem5)"
	@echo "  make clean_all            - Clean all build artifacts"
	@echo ""
	@echo "Integration with gem5:"
	@echo "  1. Terminal 1: make run"
	@echo "  2. Terminal 2: cd ../rtl_runner && ./run_gem5.sh"
